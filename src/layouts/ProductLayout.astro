---
import MainLayout from './MainLayout.astro';
import type { Locale } from '@/i18n';

interface Props {
  title: string;
  description: string;
  locale?: Locale;
  product: string;
  accent: string;
  appUrl: string;
}

const { title, description, locale = 'ko', product, accent, appUrl } = Astro.props;
const ctaLabel = locale === 'en' ? 'Try it now' : '바로 사용하기';
const docsLabel = locale === 'en' ? 'View Docs' : '문서 보기';
const prefix = locale === 'en' ? '/en' : '';
const productSlug = product.toLowerCase().replace('bs', 'bs');
---

<MainLayout title={title} description={description} locale={locale}>
  <div class="product-page">
    <slot />

    <div class="product-ctas">
      <a href={appUrl} class="cta-app" style={`background-color: ${accent};`}>
        {ctaLabel}
      </a>
      <a href={`${prefix}/${productSlug}/getting-started`} class="cta-docs">
        {docsLabel}
      </a>
    </div>
  </div>
</MainLayout>

<style>
  .product-page {
    max-width: 800px;
    margin: 0 auto;
    padding: 16px 24px 120px;
  }
  .product-page :global(h1) {
    color: #f2f3f7;
    font-size: clamp(2rem, 4vw, 2.5rem);
    font-weight: 800;
    letter-spacing: -0.035em;
    margin-bottom: 16px;
  }
  .product-page :global(.product-tagline) {
    font-size: 1.125rem;
    color: #8187a8;
    margin-bottom: 48px;
    line-height: 1.7;
  }
  .product-page :global(h2) {
    color: #f2f3f7;
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 48px 0 16px;
  }
  .product-page :global(h3) {
    color: #e4e6ee;
    font-size: 1.125rem;
    font-weight: 600;
    margin: 24px 0 8px;
  }
  .product-page :global(p) {
    color: #a8adc6;
    font-size: 0.9375rem;
    line-height: 1.8;
    margin-bottom: 16px;
  }
  .product-page :global(ul) {
    padding-left: 20px;
    margin-bottom: 16px;
  }
  .product-page :global(li) {
    color: #a8adc6;
    font-size: 0.9375rem;
    line-height: 1.8;
    margin-bottom: 8px;
  }
  .product-page :global(strong) {
    color: #e4e6ee;
  }
  .product-page :global(.feature-grid) {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 14px;
    margin: 24px 0;
  }
  .product-page :global(.feature-card) {
    padding: 24px;
    border-radius: 12px;
    border: 1px solid #2a2d42;
    background-color: #111218;
  }
  .product-page :global(.feature-card h3) {
    margin-top: 0;
  }
  .product-ctas {
    display: flex;
    gap: 12px;
    margin-top: 64px;
    justify-content: center;
  }
  .cta-app {
    display: inline-block;
    padding: 14px 32px;
    border-radius: 10px;
    color: #fff;
    font-size: 1rem;
    font-weight: 700;
    text-decoration: none;
    transition: all 0.2s ease;
  }
  .cta-app:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }
  .cta-docs {
    display: inline-block;
    padding: 14px 32px;
    border-radius: 10px;
    border: 1.5px solid #2a2d42;
    color: #8187a8;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s ease;
  }
  .cta-docs:hover {
    border-color: #8187a8;
    color: #f2f3f7;
  }
</style>
