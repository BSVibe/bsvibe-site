# Auth
AUTH_URL=https://auth.bsvibe.dev

# Supabase (billing data)
# Public — inlined into client bundle by Next.js
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only fallbacks (lib modules accept either prefix; tests stub these)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (global payment)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Toss Payments (Korea)
TOSS_SECRET_KEY=
TOSS_CLIENT_KEY=
TOSS_WEBHOOK_SECRET=
